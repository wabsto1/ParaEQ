<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Hardened-runtime builds deny audio input by default; this single
         entitlement covers both the system-audio tap and the calibration
         microphone. It is the only entitlement ParaEQ requests. -->
    <key>com.apple.security.device.audio-input</key>
    <true/>
</dict>
</plist>
